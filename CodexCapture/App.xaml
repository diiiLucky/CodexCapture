<Application x:Class="CodexCapture.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Theme/Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===== Typography ===== -->
            <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
            <FontFamily x:Key="MonoFontFamily">Consolas</FontFamily>

            <!-- ===== Primary: Blue ===== -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
            <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1E40AF" />
            <SolidColorBrush x:Key="PrimarySubtleBrush" Color="#EFF6FF" />
            <SolidColorBrush x:Key="PrimaryMutedBrush" Color="#BFDBFE" />
            <SolidColorBrush x:Key="PrimaryLightBrush" Color="#DBEAFE" />

            <!-- ===== Legacy accent keys (mapped to Primary) ===== -->
            <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="#142563EB" />

            <!-- ===== Surfaces ===== -->
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="#F8FAFC" />
            <SolidColorBrush x:Key="PanelBrush" Color="#F8FAFC" />

            <!-- ===== Text ===== -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#94A3B8" />
            <SolidColorBrush x:Key="InkBrush" Color="#0F172A" />
            <SolidColorBrush x:Key="MutedBrush" Color="#64748B" />
            <SolidColorBrush x:Key="LabelBrush" Color="#475569" />
            <SolidColorBrush x:Key="HintBrush" Color="#94A3B8" />

            <!-- ===== Borders ===== -->
            <SolidColorBrush x:Key="BorderDefaultBrush" Color="#E2E8F0" />
            <SolidColorBrush x:Key="BorderFocusBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="BorderSubtleBrush" Color="#F1F5F9" />
            <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0" />

            <!-- ===== Semantic: Status ===== -->
            <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
            <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
            <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444" />
            <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6" />

            <!-- ===== Glass / Frosted ===== -->
            <SolidColorBrush x:Key="FrostedLightBrush" Color="#E0FFFFFF" />
            <SolidColorBrush x:Key="FrostedMediumBrush" Color="#B8FFFFFF" />
            <SolidColorBrush x:Key="FrostedBrush" Color="#EBFFFFFF" />

            <!-- ===== Overlay & Capture ===== -->
            <SolidColorBrush x:Key="OverlayDimBrush" Color="#1E0F172A" />
            <SolidColorBrush x:Key="OverlayHighlightBrush" Color="#142563EB" />
            <SolidColorBrush x:Key="SelectionFillBrush" Color="#1A2563EB" />
            <SolidColorBrush x:Key="SelectionReviewFillBrush" Color="#322563EB" />
            <SolidColorBrush x:Key="SelectionBorderBrush" Color="#BFDBFE" />
            <SolidColorBrush x:Key="HudBackgroundBrush" Color="#E8FFFFFF" />
            <SolidColorBrush x:Key="HandleFillBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="HandleStrokeBrush" Color="#2563EB" />

            <!-- ===== Widget ===== -->
            <Color x:Key="WidgetInnerGradientStart">#EFF6FF</Color>
            <Color x:Key="WidgetInnerGradientEnd">#DBEAFE</Color>

            <!-- ===== Shadow ===== -->
            <Color x:Key="ShadowColor">#0F172A</Color>

            <!-- ===== Corner Radii ===== -->
            <CornerRadius x:Key="RadiusXS">4</CornerRadius>
            <CornerRadius x:Key="RadiusSM">8</CornerRadius>
            <CornerRadius x:Key="RadiusMD">12</CornerRadius>
            <CornerRadius x:Key="RadiusLG">16</CornerRadius>
            <CornerRadius x:Key="RadiusXL">20</CornerRadius>
            <CornerRadius x:Key="RadiusFull">999</CornerRadius>

            <!-- ===== Spacing (8px grid) ===== -->
            <sys:Double x:Key="SpacingXS">4</sys:Double>
            <sys:Double x:Key="SpacingSM">8</sys:Double>
            <sys:Double x:Key="SpacingMD">12</sys:Double>
            <sys:Double x:Key="SpacingLG">16</sys:Double>
            <sys:Double x:Key="SpacingXL">24</sys:Double>
            <sys:Double x:Key="Spacing2XL">32</sys:Double>

            <!-- ===== Animation Durations ===== -->
            <Duration x:Key="DurationFast">0:0:0.090</Duration>
            <Duration x:Key="DurationNormal">0:0:0.200</Duration>
            <Duration x:Key="DurationSlow">0:0:0.240</Duration>
            <Duration x:Key="DurationEntranceSpring">0:0:0.240</Duration>
            <Duration x:Key="DurationEntranceBounce">0:0:0.200</Duration>
            <Duration x:Key="DurationHover">0:0:0.180</Duration>
            <Duration x:Key="DurationPress">0:0:0.090</Duration>
            <Duration x:Key="DurationExit">0:0:0.150</Duration>
            <Duration x:Key="DurationValueChange">0:0:0.300</Duration>
            <Duration x:Key="DurationBreath">0:0:2.000</Duration>

            <!-- ===== Implicit Styles ===== -->
            <Style TargetType="{x:Type Window}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            </Style>
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            </Style>

            <!-- Unified input control styles -->
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style TargetType="{x:Type PasswordBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>

            <!-- ScrollBar styling -->
            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Width" Value="6" />
            </Style>

            <!-- ToolTip styling -->
            <Style TargetType="{x:Type ToolTip}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,6" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
