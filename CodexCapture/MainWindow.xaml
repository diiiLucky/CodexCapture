<ui:FluentWindow x:Class="CodexCapture.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="截图工具"
                 Height="460"
                 Width="360"
                 MinHeight="400"
                 MinWidth="320"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid Margin="20,20,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="截图工具" Grid.Row="0" Margin="0,0,0,14" />

        <!-- Main info card -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLG}"
                Padding="24,20,24,20"
                Effect="{x:Null}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Status indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Breathing dot -->
                    <Ellipse x:Name="StatusDot"
                             Width="8" Height="8"
                             Fill="{StaticResource SuccessBrush}"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText"
                               Text="运行中"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <!-- Row 1: Shortcut display -->
                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        CornerRadius="{StaticResource RadiusSM}"
                        Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="全局快捷键"
                                   FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,0,4" />
                        <Border Background="{StaticResource PrimarySubtleBrush}"
                                CornerRadius="{StaticResource RadiusXS}"
                                Padding="10,5"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="ShortcutText"
                                       Text="Ctrl + Alt + A"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Row 2: Info lines -->
                <StackPanel Grid.Row="2" Margin="0,18,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="FolderOpen20"
                                       FontSize="14"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,0,6,0" />
                        <TextBlock x:Name="HistoryPathText"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Crop20"
                                       FontSize="14"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,0,6,0" />
                        <TextBlock Text="悬浮按钮已启用"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 3: Quick action cards -->
                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- History card -->
                    <Border Grid.Column="0"
                            Background="{StaticResource PrimarySubtleBrush}"
                            CornerRadius="{StaticResource RadiusSM}"
                            Padding="14,12"
                            Cursor="Hand"
                            MouseLeftButtonDown="OpenHistoryFolder">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Image20"
                                           FontSize="18"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0,0,0,6" />
                            <TextBlock Text="历史截图"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock Text="打开保存目录"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Settings card -->
                    <Border Grid.Column="2"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="{StaticResource RadiusSM}"
                            Padding="14,12"
                            Cursor="Hand"
                            MouseLeftButtonDown="OpenSettings">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Settings20"
                                           FontSize="18"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,6" />
                            <TextBlock Text="设置偏好"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="快捷键 · AI · Codex"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
